# Core
APP_ENV=development
APP_DEBUG=true
APP_PORT=8000
APP_SECRET_KEY=your-secret-key
# Comma-separated list of additional CORS origins (production domains etc.)
ALLOWED_ORIGINS=

# Supabase
SUPABASE_URL=https://xxxxx.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_JWT_SECRET=

# SMTP (Email)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
FROM_EMAIL=noreply@cvlpos.jp
EMAIL_DRY_RUN=true

# Yayoi API (松プラン only)
YAYOI_CLIENT_ID=
YAYOI_CLIENT_SECRET=
YAYOI_REDIRECT_URI=
YAYOI_ENABLED=false

# Scraper
SCRAPER_REQUEST_INTERVAL_SEC=3

# Telemetry ingest (Phase 3a)
# Shared secret required in the X-Device-Token header on
# POST /api/v1/telemetry/ingest{,/batch}. Leave blank to disable ingest.
TELEMETRY_INGEST_TOKEN=

# Observability (Sentry)
# Leave SENTRY_DSN blank to disable Sentry. When set, errors and a fraction
# of traces (SENTRY_TRACES_SAMPLE_RATE, default 0.1) will be shipped.
# SENTRY_RELEASE (optional) tags events with a release identifier.
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1
SENTRY_RELEASE=
